# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# Origin(s) allowed to call this API from the browser (comma-separated).
# The Next.js dev server runs on http://localhost:3000 by default.
FRONTEND_ORIGINS=http://localhost:3000

# --- API keys (keep these SERVER-SIDE only) ---
VOYAGE_API_KEY=your-voyage-key-here          # embeddings   https://dashboard.voyageai.com
PINECONE_API_KEY=your-pinecone-key-here      # vector DB     https://app.pinecone.io
ANTHROPIC_API_KEY=your-anthropic-key-here    # Claude        https://console.anthropic.com
TAVILY_API_KEY=your-tavily-key-here          # web search    https://tavily.com

# Pinecone index settings (defaults work on the free tier).
PINECONE_INDEX=research-assistant
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Optional: model Claude uses to write answers (default claude-opus-4-8).
# ANSWER_MODEL=claude-haiku-4-5   # cheaper, for repeated testing
