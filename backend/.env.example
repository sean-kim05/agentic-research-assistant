# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# Origin(s) allowed to call this API from the browser (comma-separated).
# The Next.js dev server runs on http://localhost:3000 by default.
FRONTEND_ORIGINS=http://localhost:3000

